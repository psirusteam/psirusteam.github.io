  author = {Gutiérrez, Andrés and Zhang, Hanwen and Montaño, Cristian},
  title = {Calculo del tamaño de muestra para la estimación de una varianza en poblaciones finitas con funciones en R},
  year = {2016},
  journal = {Comunicaciones en Estadística},
  volume = {9},
  number = {1},
  pages = {109},
  doi = {10.15332/s2027-3355.2016.0001.06},
  issn = {2027-3355},
  language = {en},
  abstract = {To estimate the variance of a finite population in a standardized test is an important goal in the assessment of education; however, there is not a generalized methodology in the statistical literature that allows determining the minimum sample size necessary to estimate this parameter of interest consistently. This paper provides an approximation for the Ha ́jek estimators variance of the population variance through the Taylor linearization and proposes different approaches to computing the minimum sample size necessary to promptly estimate this parameter or even to test a system of statistical hypothesis. Additionally, we introduce computational functions written in the R software to calculate required sample sizes.}
}

