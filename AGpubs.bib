@article{Gutierrez_Zhang_2009,
  author = {Gutierrez, Andres and Zhang, Hanwen},
  title = {Análisis bayesiano para la diferencia de dos proporciones usando R},
  year = {2009},
  journal = {Revista de Metodos Cuantitativos para la Economia y la Empresa},
  volume = {8},
  number = {1},
  pages = {50–70},
  language = {es},
  abstract = {In this paper we present a collection of functions that can be used to implement a comprehensive Bayesian analysis of a difference of two proportions. For instance, point estimation, credibility intervals and predictive inference are discussed in both scenarios, the priori and posteriori exact densities (based in the first Appell hypergeometric function) and the simulated densities (based in a Markov chain Monte Carlo algorithm). We have chosen to implement the suite of functions using the R statistical software because it is freely available, runs on multiple platforms and allows to compress the functions into a single computational object named “package”.}
}

